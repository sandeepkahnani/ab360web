{
  "name": "ab360web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create ab360web-db",
    "db:schema": "wrangler d1 execute ab360web-db --remote --file=./schema.sql",
    "db:seed": "wrangler d1 execute ab360web-db --remote --file=./seed.sql",
    "db:local": "wrangler d1 execute ab360web-db --local --file=./schema.sql && wrangler d1 execute ab360web-db --local --file=./seed.sql"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "wrangler": "^3.90.0",
    "typescript": "^5.6.0"
  }
}
